rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para configuração da campanha, aberta para o painel admin.
    match /config/campaign {
      allow read, write;
    }

    // Regras para vendas, cupons e histórico de ganhadores, flexibilizadas
    // para permitir exclusão anônima durante o desenvolvimento.
    match /sales/{saleId} {
      allow read, create, delete;
    }

    match /coupons/{couponId} {
      allow read, create, delete;
    }

    match /winnersHistory/{docId} {
      allow read, create, delete;
    }
  }
}
